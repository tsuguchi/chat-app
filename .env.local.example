# Supabase
# Get these from your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: service_role key (SERVER-SIDE ONLY, never expose to client)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LiveKit Cloud
# Create a project at https://cloud.livekit.io and grab these from
# Project > Settings > Keys. The URL is public (client connects to it);
# the API key/secret stay server-side only and are used to mint room JWTs.
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxx
LIVEKIT_API_SECRET=your-livekit-api-secret
